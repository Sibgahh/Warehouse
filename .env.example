# ==============================================================
# Warehouse Management API — Environment Variables
# Copy file ini ke .env dan isi value sesuai environment.
# ==============================================================

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (MariaDB / MySQL) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=warehouse_test

# Database URL — untuk Prisma CLI (migrate, studio, db pull)
DATABASE_URL="mysql://root:@localhost:3306/warehouse_test"

# ─── JWT ──────────────────────────────────────────────────────
# Ganti dengan secret acak di production (minimal 32 karakter)
JWT_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
JWT_EXPIRES_IN="1d"

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Contoh: http://localhost:5173,http://localhost:3000
# Kosongkan untuk accept all (development only).
ALLOWED_ORIGINS=http://localhost:5173